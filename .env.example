# Public Calendly URL for "Book demo", "Book integration call", and post-form redirect
NEXT_PUBLIC_CALENDLY_URL=

# Server-side POST target for lead payloads from /book-demo (Zapier, Make, etc.)
LEADS_WEBHOOK_URL=

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_SECRET_KEY=

# Admin setup
ADMIN_SETUP_TOKEN=

# App URL (used to build webhook callback URLs for payment rails)
NEXT_PUBLIC_APP_URL=

# PayRam (Rail 1) — self-hosted Core: API lives under /api/v1 (SDK adds paths).
# PAYRAM_API_URL = origin only, no trailing slash, e.g. http://EXTERNAL_IP:8080
# Checkout uses each merchant's key from DB (Admin → Merchants), not Vercel, so each merchant only hits their PayRam project.
# PAYRAM_API_KEY / PAYRAM_API_URL: optional webhook verify fallback + base URL when merchant row omits payram_base_url.
# Legacy only: allow all merchants to share global env client (not multi-tenant safe).
# PAYRAM_USE_GLOBAL_CLIENT_FOR_MERCHANTS=true
PAYRAM_API_KEY=
PAYRAM_API_URL=

# Inqud (Rail 2) — get credentials after KYB at app.inqud.com
INQUD_API_TOKEN_ID=
INQUD_API_TOKEN_SECRET=
INQUD_PROJECT_ID=
# Must match the callback secret in Inqud; verify X-Payload-Digest (HMAC-SHA1 of raw body)
INQUD_WEBHOOK_SECRET=

# Alchemy Pay (Rail 3) — NOT alchemy.com (RPC). Docs: https://alchemypay.readme.io/ — credentials from Alchemy Pay ops after KYB
ALCHEMY_PAY_APP_ID=
ALCHEMY_PAY_APP_SECRET=
ALCHEMY_PAY_BASE_URL=https://openapi.alchemypay.org



NEXAPAY_WEBHOOK_SECRET=
NEXAPAY_BASE_URL=
NEXAPAY_APP_ID=
# Meta (Facebook) Pixel ID (client-side; safe to expose). Set real value in Vercel.
NEXT_PUBLIC_META_PIXEL_ID=
